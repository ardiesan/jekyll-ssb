# ==============================================================================
# SECURITY-HARDENED DOCKER .GITIGNORE
# ==============================================================================

# ------------------------------------------------------------------------------
# Secrets & Credentials (CRITICAL)
# ------------------------------------------------------------------------------
# Never commit raw credentials, tokens, or environment files
*.env
*.env.*
*.envrc
!*.env.example
*.bak
*.conf
*.pem
*.key
*.pub
*.crt
*.p12
*.secret
*secret*
*credential*

# ------------------------------------------------------------------------------
# Docker Build & Runtime Artifacts
# ------------------------------------------------------------------------------
# Ignore local container states, exports, and build logs
.dockerignore
docker-compose.override.yml
*.tar
*.tar.gz
*.tar.xz
docker-image-*.tgz

# Ignore standard Docker volume mount points if they reside in the project root
/data/
/db/
/logs/
*.log

# ------------------------------------------------------------------------------
# IDE, OS, and System Files (Can leak path structures or metadata)
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ------------------------------------------------------------------------------
# Language/Framework Dependencies (Should be built inside the Dockerfile)
# ------------------------------------------------------------------------------
# Doing this prevents poisoning the Docker build context with local OS-specific binaries
node_modules/
bower_components/
venv/
.venv/
.*/
env/
__pycache__/
*.pyc
vendor/
bin/
obj/
